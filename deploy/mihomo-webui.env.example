# Пример env-файла для mihomo-webui.
#
# Скопируйте в /etc/mihomo-webui.env (system-wide) или
# ~/.config/mihomo-webui.env (rootless), затем заполните MIKROTIK_* переменные
# и опционально WEBUI_USER / WEBUI_PASSWORD_HASH для basic auth.
#
# Файл читается systemd через EnvironmentFile= в Quadlet-юните, поэтому
# значения НЕ должны быть в кавычках (systemd понимает их как часть значения).
# Не используйте `export`, не используйте подстановки `${VAR}`.
#
# После изменений выполните:
#   sudo systemctl restart mihomo-webui.service

# ---------- MikroTik REST API ----------

# URL роутера со схемой. HTTPS требует включённого www-ssl с валидным
# сертификатом (либо MIKROTIK_VERIFY_TLS=false для self-signed).
# HTTP допускается в доверенной LAN.
#   Пример HTTP:  MIKROTIK_HOST=http://192.168.88.1
#   Пример HTTPS: MIKROTIK_HOST=https://192.168.88.1
MIKROTIK_HOST=http://192.168.88.1

# Логин и пароль RouterOS. Рекомендуется завести отдельного пользователя
# с группой `full` (или хотя бы `read,write,policy` для container/script/dns).
MIKROTIK_USER=admin
MIKROTIK_PASSWORD=changeme

# Проверять TLS сертификат RouterOS. Для self-signed — false.
MIKROTIK_VERIFY_TLS=false

# Таймаут одного REST-запроса (секунды).
MIKROTIK_TIMEOUT=10

# Отдельный таймаут (секунды) для шага run_router_script — запуска
# генерируемого из meta-rules-dat .list скрипта DNS-FWD на роутере. Крупные
# категории (например amazon, сотни /ip dns static add строк) исполняются
# на RouterOS дольше стандартного MIKROTIK_TIMEOUT. Применяется только к
# POST /rest/system/script/run; остальные REST-вызовы используют
# MIKROTIK_TIMEOUT.
# RUN_SCRIPT_TIMEOUT=600

# Таймаут (секунды) шага wait_stopped — сколько ждать перехода контейнера в
# состояние stopped после stop_container. Останов обычно занимает считанные
# секунды.
WAIT_STOPPED_TIMEOUT=60

# Таймаут (секунды) шага wait_running. Если задан MIHOMO_API_URL, шаг
# опрашивает корневой эндпойнт mihomo (GET <MIHOMO_API_URL>/) и считается
# успешным, когда тело ответа начинается с `{` (welcome JSON mihomo). Когда
# в конфиге mihomo задан `secret:`, маршрут `/` тоже под bearer-auth — в
# таком случае шаг также трактует 401/403 как «контейнер поднялся»
# (HTTP-listener отвечает, просто bearer не подходит), чтобы при пустом
# или неправильном MIHOMO_API_SECRET шаг не висел до полного таймаута;
# фактическую auth-ошибку поднимет следующий вызов /providers/rules.
# RouterOS REST на холодном старте может удерживать status=<empty> всё
# окно ожидания, пока контейнер уже работает, поэтому опрос
# HTTP-listener'а mihomo надёжнее. Если MIHOMO_API_URL не задан, шаг
# строго ждёт running через RouterOS REST. Холодный старт mihomo-proxy-ros
# (распаковка образа, подписки, rule-providers) на медленных роутерах легко
# превышает 60 с, поэтому дефолт заметно больше, чем для остановки.
WAIT_RUNNING_TIMEOUT=180

# Legacy fallback для двух предыдущих переменных. Если задан и
# WAIT_STOPPED_TIMEOUT/WAIT_RUNNING_TIMEOUT отсутствуют, его значение
# применяется к обоим шагам — чтобы существующие env-файлы продолжали
# работать без изменений. Явные WAIT_*_TIMEOUT имеют приоритет.
# CONTAINER_WAIT_TIMEOUT=60

# Comment контейнера mihomo-proxy-ros на RouterOS (используется для поиска
# его id через REST API). По умолчанию script21.rsc выставляет это значение.
MIKROTIK_CONTAINER_COMMENT=MihomoProxyRoS

# Имя envlist на RouterOS, в котором лежат ENV переменные mihomo-proxy-ros.
# В script21.rsc envlist называется так же, как comment.
MIKROTIK_ENVS_LIST=MihomoProxyRoS

# ---------- Mihomo external-controller (опционально) ----------

# URL mihomo external-controller внутри контейнера mihomo-proxy-ros.
# Если задан, web UI после рестарта контейнера ждёт, пока mihomo действительно
# загрузит провайдеры правил, и только потом сбрасывает DNS-кэш роутера —
# иначе резолвер может пару секунд отдавать fake-ip с непримененными правилами.
# Если переменная пустая, шаг wait_mihomo_ready отсутствует.
#   Пример: http://192.168.255.2:9090
# MIHOMO_API_URL=http://192.168.255.2:9090

# Bearer-секрет mihomo external-controller (если в его конфиге задан secret:).
# MIHOMO_API_SECRET=

# Таймаут (секунды) шага wait_mihomo_ready — ждём, пока у всех провайдеров
# правил с vehicleType != Inline появится ненулевой updatedAt (правила
# скачаны и применены). Проверка «mihomo HTTP отвечает» уже сделана в
# предыдущем шаге wait_running через GET /, поэтому здесь нет отдельного
# опроса /version. По умолчанию 90 секунд.
# MIHOMO_READY_TIMEOUT=90

# ---------- Web UI ----------

# Basic auth. Если обе переменные пустые — авторизация отключена (UI открыт
# всем, кто имеет доступ к порту WEBUI_PORT). Хеш генерируется командой:
#   podman run --rm caddy:2-alpine caddy hash-password --plaintext '<пароль>'
# Результат имеет вид $2a$14$abcdef... Вставьте его в WEBUI_PASSWORD_HASH
# как есть, без кавычек и без экранирования символов `$`: и systemd
# EnvironmentFile=, и `podman --env-file` читают значения построчно
# верботим, без подстановок переменных.
WEBUI_USER=
WEBUI_PASSWORD_HASH=

# ---------- Backend (только при отладке) ----------

# Где Caddy ищет uvicorn-backend внутри контейнера. Менять обычно не нужно —
# дефолты совпадают со значениями, выставленными в Containerfile.
# BACKEND_HOST=127.0.0.1
# BACKEND_PORT=8000

# Порт, на котором Caddy слушает ВНУТРИ контейнера. Менять обычно не нужно —
# проброс на хост выставлен в Quadlet-юните через PublishPort=.
WEBUI_PORT=80
